# k8s commands
alias k8s-ctx-eu="kubectl config use-context gke_tenderly-project_europe-west3-a_production-eu-west3"
alias k8s-ctx-use="kubectl config use-context gke_tenderly-project_us-east4_production-us-east4"
alias k8s-ctx-usw="kubectl config use-context gke_tenderly-project_us-west1_production-us-west1"

alias k8s-ctx="kubectl config current-context"

function k8s-scale() {
  region=$1
  deployment=$2
  replicas=$3

  ctx=$(k8s-ctx)

  eval k8s-ctx-$region
  kubectl scale deployment $deployment --replicas=$replicas -n tenderly
  kubectl config use-context $ctx
}