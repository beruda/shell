#!/bin/zsh

function mkcd() {
    mkdir $1
    cd $1
}

function close-port() {
    sudo kill -9 $(sudo lsof -t -sTCP:LISTEN -i:$1)
}

function secret() {
  gcloud secrets versions access latest --secret=$1
  echo
}

